generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MEMBER
  COACH
  ADMIN
}

enum SessionType {
  OPEN_PLAY
  JUNIOR
  SOCIAL
  COACHED
}

enum SessionStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum ProductCategory {
  APPAREL
  ACCESSORIES
  EQUIPMENT
  OTHER
}

enum SponsorTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum SponsorStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CompetitionStatus {
  UPCOMING
  OPEN
  CLOSED
  ONGOING
  FINISHED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(MEMBER)
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      AuthSession[]
  bookings      Booking[]
  orders        Order[]
  coachProfile  Coach?
  registrations CompetitionRegistration[]
  donations     Donation[]
  consentLogs   CookieConsent[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PlaySession {
  id          String        @id @default(cuid())
  title       String
  type        SessionType
  description String?
  location    String        @default("School Sports Hall, CosmaClub")
  court       String?
  dayOfWeek   Int
  startTime   String
  endTime     String
  date        DateTime?
  isRecurring Boolean       @default(true)
  maxPlayers  Int?
  priceStd    Float
  priceMember Float
  priceJunior Float?
  status      SessionStatus @default(SCHEDULED)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  bookings Booking[]

  @@map("play_sessions")
}

model Booking {
  id              String        @id @default(cuid())
  userId          String
  sessionId       String?
  coachId         String?
  date            DateTime
  startTime       String
  endTime         String
  amount          Float
  stripePaymentId String?       @unique
  status          BookingStatus @default(PENDING)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user    User         @relation(fields: [userId], references: [id])
  session PlaySession? @relation(fields: [sessionId], references: [id])
  coach   Coach?       @relation(fields: [coachId], references: [id])

  @@map("bookings")
}

model Coach {
  id            String   @id @default(cuid())
  userId        String   @unique
  bio           String?
  qualification String?
  specialisms   String[]
  pricePerHour  Float
  imageUrl      String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user         User           @relation(fields: [userId], references: [id])
  bookings     Booking[]
  availability Availability[]

  @@map("coaches")
}

model Availability {
  id        String  @id @default(cuid())
  coachId   String
  dayOfWeek Int
  startTime String
  endTime   String
  isBlocked Boolean @default(false)

  coach Coach @relation(fields: [coachId], references: [id], onDelete: Cascade)

  @@map("coach_availability")
}

model Competition {
  id          String            @id @default(cuid())
  title       String
  description String?
  location    String            @default("School Sports Hall, CosmaClub")
  startDate   DateTime
  endDate     DateTime?
  entryFee    Float             @default(0)
  maxPlayers  Int?
  format      String?
  status      CompetitionStatus @default(UPCOMING)
  rules       String?           @db.Text
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  registrations CompetitionRegistration[]

  @@map("competitions")
}

model CompetitionRegistration {
  id              String    @id @default(cuid())
  userId          String
  competitionId   String
  paidAt          DateTime?
  stripePaymentId String?   @unique
  notes           String?
  createdAt       DateTime  @default(now())

  user        User        @relation(fields: [userId], references: [id])
  competition Competition @relation(fields: [competitionId], references: [id])

  @@unique([userId, competitionId])
  @@map("competition_registrations")
}

model Product {
  id          String          @id @default(cuid())
  name        String
  description String?
  price       Float
  imageUrl    String?
  category    ProductCategory @default(OTHER)
  stock       Int             @default(0)
  isActive    Boolean         @default(true)
  sizes       String[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  orderItems OrderItem[]

  @@map("products")
}

model Order {
  id              String      @id @default(cuid())
  userId          String
  total           Float
  stripePaymentId String?     @unique
  status          OrderStatus @default(PENDING)
  shippingAddress Json?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user  User        @relation(fields: [userId], references: [id])
  items OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  size      String?

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Donation {
  id              String   @id @default(cuid())
  userId          String?
  amount          Float
  message         String?
  isAnonymous     Boolean  @default(false)
  stripePaymentId String?  @unique
  createdAt       DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("donations")
}

model SponsorApplication {
  id          String        @id @default(cuid())
  companyName String
  contactName String
  email       String
  phone       String?
  website     String?
  tier        SponsorTier
  message     String?       @db.Text
  status      SponsorStatus @default(PENDING)
  reviewedAt  DateTime?
  reviewNotes String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("sponsor_applications")
}

model CookieConsent {
  id          String   @id @default(cuid())
  userId      String?
  sessionId   String?
  essential   Boolean  @default(true)
  analytics   Boolean  @default(false)
  marketing   Boolean  @default(false)
  consentedAt DateTime @default(now())
  userAgent   String?

  user User? @relation(fields: [userId], references: [id])

  @@map("cookie_consents")
}